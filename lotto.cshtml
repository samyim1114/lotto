<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>六合彩科學模擬器 | 極速複式機率與期望值 (EV) 分析工具</title>
    <meta name="description" content="全港最強六合彩模擬工具！支持多張彩票、複式投注實時計算。透過大數據模擬，揭示六合彩中獎機率與期望值 (EV)，助你科學看透博彩真相。">
    <meta name="keywords" content="六合彩, 模擬器, 複式機率, 期望值計算, Mark Six Simulator, 香港六合彩, 博彩科學, 蒙地卡羅模擬">
    <link rel="canonical" href="https://你的網址.com/">
    
    <meta property="og:title" content="六合彩科學模擬器 - 你離頭獎到底有多遠？">
    <meta property="og:description" content="即時模擬萬期開獎，計算複式投注回報，看透負期望值的博弈本質。">
    <meta property="og:type" content="website">

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <style>
        :root { --primary: #4caf50; --bg: #121212; --card: #1e1e1e; --loss: #ff5252; --win: #00e676; }
        body { font-family: 'Segoe UI', "Microsoft JhengHei", sans-serif; background: var(--bg); color: #e0e0e0; display: flex; flex-direction: column; align-items: center; padding: 20px; margin: 0; }
        .container { background: var(--card); padding: 25px; border-radius: 15px; width: 100%; max-width: 1000px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        
        /* [廣告位樣式預留] */
        .ad-space { background: #262626; border: 1px dashed #444; margin: 15px 0; display: flex; align-items: center; justify-content: center; color: #666; font-size: 12px; min-height: 90px; border-radius: 8px; overflow: hidden; }
        
        .ticket-box { background: #2d2d2d; padding: 15px; border-radius: 10px; margin-bottom: 10px; border-left: 5px solid #2196f3; }
        .grid-49 { display: grid; grid-template-columns: repeat(13, 1fr); gap: 4px; margin-top: 5px; }
        .num-btn { padding: 4px; background: #444; border: 1px solid #555; color: white; cursor: pointer; border-radius: 3px; font-size: 11px; }
        .num-btn.selected { background: var(--primary); border-color: #fff; }
        .controls { display: flex; gap: 10px; margin: 20px 0; align-items: center; background: #262626; padding: 15px; border-radius: 10px; flex-wrap: wrap; }
        input[type="number"] { background: #333; border: 1px solid #555; color: #ffeb3b; padding: 8px; border-radius: 5px; width: 120px; font-weight: bold; }
        button { padding: 10px 20px; cursor: pointer; border: none; border-radius: 5px; font-weight: bold; }
        .btn-add { background: #9c27b0; color: white; }
        .btn-once { background: #ff9800; color: white; }
        .btn-start { background: #2196f3; color: white; }
        .btn-stop { background: #f44336; color: white; }
        .panel { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }
        .card { background: #2d2d2d; padding: 20px; border-radius: 10px; border-top: 4px solid var(--primary); }
        .prize-row { display: flex; justify-content: space-between; border-bottom: 1px solid #444; padding: 6px 0; font-size: 13px; }
        .profit-pos { color: var(--win); }
        .profit-neg { color: var(--loss); }
        @media (max-width: 768px) { .panel { grid-template-columns: 1fr; } .grid-49 { grid-template-columns: repeat(7, 1fr); } }
    </style>
</head>
<body>

<div class="container">
    <div class="ad-space">
        <span>廣告展示區域 (未來放置 Google AdSense)</span>
    </div>

    <h1>香港六合彩科學模擬器</h1>
    
    <div style="margin-bottom: 15px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
        <div>
            <label>設定頭獎金額 (HKD): </label>
            <input type="number" id="jackpotInput" value="8000000" onchange="updateUI()">
        </div>
        <button class="btn-add" onclick="addTicket()">+ 新增一組號碼</button>
    </div>

    <div id="ticketsContainer"></div>

    <div class="controls">
        <button class="btn-once" onclick="drawOnce()">手動開獎</button>
        <button class="btn-start" id="runBtn" onclick="toggleSim()">自動極速模擬</button>
        <button onclick="resetAll()" style="background:#666; color:white;">清空所有數據</button>
        <span id="status">準備就緒</span>
    </div>

    <div class="panel">
        <div class="card" style="border-top-color: #2196f3;">
            <h3>實戰財務報表</h3>
            <div class="prize-row"><span>累積期數:</span> <span id="draws">0</span></div>
            <div class="prize-row"><span>總注數:</span> <span id="totalLines">0</span></div>
            <div class="prize-row"><span>累積投資:</span> <span id="totalCost" class="profit-neg">$0</span></div>
            <div class="prize-row"><span>累積獎金:</span> <span id="totalRev" class="profit-pos">$0</span></div>
            <hr>
            <div class="prize-row" style="font-size: 1.3em; font-weight: bold;">
                <span>純利 (Profit):</span> <span id="totalProfit">$0</span>
            </div>
        </div>

        <div class="card">
            <h3>中獎次數統計</h3>
            <div id="prizeStats"></div>
        </div>
    </div>

    <div class="card" style="border-top-color: #ffeb3b; margin-top: 20px;">
        <h3>📊 全局勝率與期望值 (EV) 分析</h3>
        <div id="probDisplay" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;"></div>
        <hr style="border: 0; border-top: 1px dashed #555; margin: 15px 0;">
        <div class="prize-row" style="font-size: 1.1em; font-weight: bold;">
            <span>每期總期望回報 (Total EV):</span>
            <span id="evResult" style="color:#ffeb3b;">$0</span>
        </div>
        <div class="prize-row">
            <span>每期預期淨損益:</span>
            <span id="netEvResult" class="profit-neg">$0</span>
        </div>
    </div>

    <div class="ad-space" style="margin-top: 25px;">
        <span>廣告展示區域 (推薦放置 728x90 橫幅廣告)</span>
    </div>

    <footer style="margin-top: 20px; font-size: 12px; color: #666; text-align: center;">
        本工具僅供機率模擬教學用途，博彩受機率限制，請理性看待。
    </footer>
</div>

<script>
    let tickets = [];
    let isRunning = false;
    let stats = { draws: 0, p1:0, p2:0, p3:0, p4:0, p5:0, p6:0, p7:0, totalPrizeMoney: 0 };
    
    const PRIZE_DEF = [
        { id: 1, name: "頭獎 (6正)", prob: 1/13983816 },
        { id: 2, name: "二獎 (5正+特)", amt: 1000000, prob: 1/2330636 },
        { id: 3, name: "三獎 (5正)", amt: 40000, prob: 1/54201 },
        { id: 4, name: "四獎 (4正+特)", amt: 9600, prob: 1/22197 },
        { id: 5, name: "五獎 (4正)", amt: 640, prob: 1/1083 },
        { id: 6, name: "六獎 (3正+特)", amt: 320, prob: 1/812 },
        { id: 7, name: "七獎 (3正)", amt: 40, prob: 1/61 }
    ];

    function combinations(n, k) {
        if (k > n) return 0;
        let r = 1;
        for (let i = 1; i <= k; i++) r = r * (n - i + 1) / i;
        return Math.round(r);
    }

    function addTicket() {
        const id = Date.now();
        const ticketSet = new Set();
        tickets.push({ id, set: ticketSet });
        const container = document.getElementById('ticketsContainer');
        const box = document.createElement('div');
        box.className = 'ticket-box';
        box.id = `ticket-${id}`;
        box.innerHTML = `
            <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:5px;">
                <strong>投注組合 #${tickets.length}</strong>
                <button onclick="removeTicket(${id})" style="background:none; color:#ff5252; border:none; cursor:pointer;">[刪除]</button>
            </div>
            <div class="grid-49" id="grid-${id}"></div>
        `;
        container.appendChild(box);
        const grid = document.getElementById(`grid-${id}`);
        for (let i = 1; i <= 49; i++) {
            let b = document.createElement('button');
            b.className = 'num-btn';
            b.innerText = i;
            b.onclick = () => {
                if (ticketSet.has(i)) { ticketSet.delete(i); b.classList.remove('selected'); }
                else { ticketSet.add(i); b.classList.add('selected'); }
                updateUI();
            };
            grid.appendChild(b);
        }
        updateUI();
    }

    function removeTicket(id) {
        tickets = tickets.filter(t => t.id !== id);
        document.getElementById(`ticket-${id}`).remove();
        updateUI();
    }

    function resetAll() {
        isRunning = false;
        tickets = [];
        document.getElementById('ticketsContainer').innerHTML = '';
        stats = { draws: 0, p1:0, p2:0, p3:0, p4:0, p5:0, p6:0, p7:0, totalPrizeMoney: 0 };
        updateUI();
        addTicket();
    }

    function toggleSim() {
        if (isRunning) { isRunning = false; return; }
        if (tickets.length === 0 || tickets.some(t => t.set.size < 6)) return alert("請正確填寫號碼 (每組至少6個)");
        isRunning = true;
        document.getElementById('runBtn').innerText = "停止模擬";
        document.getElementById('runBtn').className = "btn-stop";
        loop();
    }

    function drawOnce() {
        if (tickets.length === 0 || tickets.some(t => t.set.size < 6)) return alert("請正確填寫號碼");
        performDraw();
        updateUI();
    }

    function performDraw() {
        stats.draws++;
        let pool = Array.from({length: 49}, (_, i) => i + 1);
        let dMain = [];
        for(let j=0; j<6; j++) dMain.push(pool.splice(Math.floor(Math.random()*pool.length), 1)[0]);
        let dSpec = pool[Math.floor(Math.random()*pool.length)];
        const customJackpot = parseFloat(document.getElementById('jackpotInput').value) || 8000000;

        tickets.forEach(t => {
            let mMain = Array.from(t.set).filter(n => dMain.includes(n)).length;
            let mSpec = t.set.has(dSpec) ? 1 : 0;
            let n = t.set.size;

            if (mMain === 6) { stats.p1++; stats.totalPrizeMoney += customJackpot + (combinations(n-6, 1) * 40000); isRunning = false; }
            else if (mMain === 5 && mSpec) { stats.p2++; stats.totalPrizeMoney += 1000000; }
            else if (mMain === 5) { stats.p3++; stats.totalPrizeMoney += 40000; }
            else if (mMain === 4 && mSpec) { stats.p4++; stats.totalPrizeMoney += 9600; }
            else if (mMain === 4) { stats.p5++; stats.totalPrizeMoney += 640; }
            else if (mMain === 3 && mSpec) { stats.p6++; stats.totalPrizeMoney += 320; }
            else if (mMain === 3) { stats.p7++; stats.totalPrizeMoney += 40; }
        });
    }

    function loop() {
        if (!isRunning) {
            document.getElementById('runBtn').innerText = "自動極速模擬";
            document.getElementById('runBtn').className = "btn-start";
            return;
        }
        for (let k = 0; k < 1000; k++) {
            performDraw();
            if (!isRunning) { alert("恭喜中頭獎！模擬結束。"); break; }
        }
        updateUI();
        requestAnimationFrame(loop);
    }

    function updateUI() {
        let totalLines = 0;
        tickets.forEach(t => totalLines += combinations(t.set.size, 6));
        const jackpot = parseFloat(document.getElementById('jackpotInput').value) || 8000000;
        const cost = stats.draws * totalLines * 10;
        const profit = stats.totalPrizeMoney - cost;

        document.getElementById('draws').innerText = stats.draws.toLocaleString();
        document.getElementById('totalLines').innerText = totalLines.toLocaleString();
        document.getElementById('totalCost').innerText = "-$" + cost.toLocaleString();
        document.getElementById('totalRev').innerText = "+$" + stats.totalPrizeMoney.toLocaleString();
        const pElem = document.getElementById('totalProfit');
        pElem.innerText = (profit >= 0 ? "+$" : "-$") + Math.abs(profit).toLocaleString();
        pElem.className = profit >= 0 ? "profit-pos" : "profit-neg";

        let statHtml = '';
        PRIZE_DEF.forEach(p => statHtml += `<div class="prize-row"><span>${p.name}:</span> <span>${stats['p'+p.id].toLocaleString()} 次</span></div>`);
        document.getElementById('prizeStats').innerHTML = statHtml;

        let probHtml = '';
        let totalEV = 0;
        PRIZE_DEF.forEach(p => {
            const amt = (p.id === 1) ? jackpot : p.amt || 0;
            let combinedProb = p.prob * totalLines; 
            probHtml += `<div class="prize-row"><span>${p.name}機率:</span> <span>${(Math.min(combinedProb * 100, 100)).toFixed(6)}%</span></div>`;
            totalEV += (p.prob * totalLines) * amt;
        });
        document.getElementById('probDisplay').innerHTML = probHtml;
        document.getElementById('evResult').innerText = "$" + totalEV.toFixed(2);
        const netEv = totalEV - (totalLines * 10);
        document.getElementById('netEvResult').innerText = (netEv >= 0 ? "+$" : "-$") + Math.abs(netEv).toFixed(2);
        document.getElementById('netEvResult').className = netEv >= 0 ? "profit-pos" : "profit-neg";
        document.getElementById('status').innerText = isRunning ? "模擬運行中..." : "系統就緒";
    }

    addTicket();
</script>

</body>
</html>
